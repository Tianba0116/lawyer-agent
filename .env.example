# ── API Keys（在 providers.json 中通过 api_key_env 引用）──

# DeepSeek 官方 API
DEEPSEEK_API_KEY=your_api_key_here

# 通义千问 (阿里云 DashScope)
QWEN_API_KEY=your_api_key_here

# Moonshot (Kimi)
MOONSHOT_API_KEY=your_api_key_here

# 智谱 GLM
ZHIPU_API_KEY=your_api_key_here

# 豆包 (字节火山引擎)
DOUBAO_API_KEY=your_api_key_here

# ── Embedding ──
EMBED_PROVIDER=huggingface
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Retrieval（可选）──
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200
# TOP_K=5

# ── OCR 扫描件处理（可选）──
# OCR_DPI=150                 # 扫描精度，默认 150（越高越清晰但越慢）
# OCR_TABLE_RECOGNITION=1     # 表格识别，1=开启 0=关闭（关闭提速 ~50%）
# OCR_MODE=accurate           # accurate=完整识别 | fast=快速（关闭表格）

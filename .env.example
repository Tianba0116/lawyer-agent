# ═══════════════════════════════════════════════════════════
#  AI 法律助手 — 环境变量模板
#  复制此文件到 backend/.env 后填入实际值
#    cp .env.example backend/.env
# ═══════════════════════════════════════════════════════════

# ── LLM API Keys（至少填一个）──────────────────────────────
# 获取地址：
#   DeepSeek:   https://platform.deepseek.com/api_keys
#   通义千问:    https://dashscope.console.aliyun.com/apiKey
#   Moonshot:   https://platform.moonshot.cn/console/api-keys
#   智谱 GLM:   https://open.bigmodel.cn/usercenter/apikeys
#   豆包:       https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey

DEEPSEEK_API_KEY=your_api_key_here
# QWEN_API_KEY=your_api_key_here
# MOONSHOT_API_KEY=your_api_key_here
# ZHIPU_API_KEY=your_api_key_here
# DOUBAO_API_KEY=your_api_key_here

# ── HuggingFace 镜像（国内必配！否则模型下载失败）─────────
# 默认使用 hf-mirror.com 国内镜像
# 如果人在海外或镜像挂了，注释掉这行即可
HF_ENDPOINT=https://hf-mirror.com

# ── Embedding ────────────────────────────────────────────
# huggingface = 免费本地模型（推荐，需要 ~100MB 下载模型）
# ollama = 本地 Ollama 服务（需自行安装 Ollama）
EMBED_PROVIDER=huggingface
HF_EMBED_MODEL=BAAI/bge-small-zh-v1.5
# HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2  # 英文备选

# ── Retrieval（可选）─────────────────────────────────────
# CHUNK_SIZE=1000        # 文本块大小（越大越完整，越小越精准）
# CHUNK_OVERLAP=200      # 块间重叠（避免关键信息被切断）
# TOP_K=5                # 检索返回数量

# ── OCR 扫描件处理（可选）────────────────────────────────
# 仅当需要处理扫描件/图片型 PDF 时需要
# OCR_DPI=150            # 扫描精度，默认 150（越高越清晰但越慢）
# OCR_TABLE_RECOGNITION=1 # 表格识别：1=开启 0=关闭（关闭提速 ~50%）
# OCR_MODE=accurate      # accurate=完整识别 | fast=快速模式
